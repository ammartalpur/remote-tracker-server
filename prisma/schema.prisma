
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Employee {
  id          String   @id @default(uuid())
  name        String?  // Initially null during pairing, filled out by owner later
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  devices     Device[]
}

model Device {
  id           String   @id @default(uuid())
  employeeId   String
  employee     Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  
  hostname     String   // Desktop name (e.g., DESKTOP-AMMAR-92)
  os           String   // Operating System
  macAddress   String   @unique // Permanent hardware identifier
  lastIp       String   // Last known public IP
  location     String   // Calculated physical location (City, Country)
  authToken    String   @unique // Secure JWT token for automatic reconnection
  activeApp    String?
  isVerified   Boolean  @default(false)
  isActive     Boolean  @default(false)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  sessions     Session[]
}

model Session {
  id          String        @id @default(uuid())
  deviceId    String
  device      Device        @relation(fields: [deviceId], references: [id], onDelete: Cascade)
  
  startedAt   DateTime      @default(now())
  endedAt     DateTime?     // Remains null while they are online
  durationMin Int?          // Calculated automatically when they disconnect
  
  activities  ActivityLog[] // Links to the apps they used during this specific session
}

model ActivityLog {
  id          String   @id @default(uuid())
  sessionId   String
  session     Session  @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  
  appName     String   // e.g., "Visual Studio Code"
  timestamp   DateTime @default(now()) // The exact moment they switched to this app
}